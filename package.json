{
  "name": "labassist",
  "version": "1.0.0",
  "description": "LabAssist - CSE Lab Portal Monorepo",
  "private": true,
  "workspaces": [
    "apps/api",
    "apps/web"
  ],
  "scripts": {
    "dev": "concurrently --kill-others-on-fail --names \"API,WEB\" --prefix-colors \"blue,green\" \"npm run start:dev --workspace=apps/api\" \"npm run dev --workspace=apps/web\"",
    "dev:api": "npm run start:dev --workspace=apps/api",
    "dev:web": "npm run dev --workspace=apps/web",
    "build:api": "npm run build --workspace=apps/api",
    "build:web": "npm run build --workspace=apps/web",
    "lint": "npm run lint --workspaces --if-present"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
